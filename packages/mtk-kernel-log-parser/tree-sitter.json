{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "kernellog",
      "camelcase": "Kernellog",
      "title": "parse android kernel log and transform",
      "scope": "source.kernellog",
      "file-types": [
        "*"
      ],
      "injection-regex": "^kernellog$",
      "class-name": "TreeSitterKernellog"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Kernellog grammar for tree-sitter",
    "authors": [
      {
        "name": "anan",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-kernellog",
      "funding": "'"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}