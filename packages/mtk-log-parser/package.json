{
  "name": "mtk-log-parser",
  "version": "1.0.0",
  "description": "Unified log parser for Android and Kernel logs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  },
  "dependencies": {
    "@ast-grep/napi": "0.42.1",
    "mtk-android-log-parser": "workspace:*",
    "mtk-kernel-log-parser": "workspace:*"
  }
}
