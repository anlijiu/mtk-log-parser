{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "androidlog",
      "camelcase": "Androidlog",
      "title": "Androidlog",
      "scope": "source.androidlog",
      "file-types": [
        "*"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^androidlog$",
      "class-name": "TreeSitterAndroidlog"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "main log & sys log",
    "authors": [
      {
        "name": "anan",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-androidlog",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
